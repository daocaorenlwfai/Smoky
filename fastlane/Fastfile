# Fastlane Fastfile — screenshots + metadata management

default_platform(:ios)

platform :ios do
  desc "Capture screenshots in all device sizes"
  lane :screenshots do
    capture_screenshots(
      scheme: "MobileAppTemplate",
      devices: [
        "iPhone 8 Plus",
        "iPhone 15 Pro Max",
        "iPad Pro (12.9-inch) (6th generation)",
      ],
      languages: ["en-US", "zh-Hans"],
      localize_simulator: true,
      reinstall_app: true,
      erase_simulator: true,
    )
  end

  desc "Upload screenshots and metadata to App Store Connect"
  lane :upload_metadata do
    upload_to_app_store(
      force: true,
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        add_id_info_serves_ads: false,
        content_rights_has_rights: true,
      }
    )
  end

  desc "Download existing metadata from App Store Connect"
  lane :download_metadata do
    deliver(
      username: ENV["APPLE_ID_EMAIL"],
      app_identifier: ENV["APP_STORE_APP_ID"],
      overwrite_screenshots: false,
      skip_binary_upload: true,
    )
  end
end

platform :android do
  desc "Upload Android metadata to Google Play"
  lane :upload_metadata do
    upload_to_play_store(
      json_key: ENV["ANDROID_SERVICE_ACCOUNT_KEY_PATH"],
      track: "production",
      metadata_path: "./fastlane/metadata/android",
    )
  end
end
