# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/<your-project>/settings/api
# Dev project (safe to reset/seed)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id-dev.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project-id-dev.supabase.co/functions/v1

# ── RevenueCat ───────────────────────────────────────────────
# RevenueCat SDK Key — single key for both iOS & Android.
# Get from: RevenueCat dashboard → API Keys → SDK API Keys → Show key
# Same key in both .env files (TestFlight sandbox auto-detected).
EXPO_PUBLIC_REVENUECAT_API_KEY=rcg_xx...xx

# ── PostHog ──────────────────────────────────────────────────
# Get from: https://app.posthog.com/project/<id>/settings
EXPO_PUBLIC_POSTHOG_API_KEY=***

# ── Sentry ───────────────────────────────────────────────────
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ENVIRONMENT=development